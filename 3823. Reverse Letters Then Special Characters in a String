class Solution {
    public String reverseByType(String s) {
        String a="";
        String sp="";
        String r="";
        for(int i=0;i<s.length();i++){
            char b=s.charAt(i);
            if(b>=97 && b<=122) a+=b;
            else sp+=b;
        }
        String ra="";
        String rsp="";
         for(int i=a.length()-1;i>=0;i--) ra+=a.charAt(i);
         for(int i=sp.length()-1;i>=0;i--) rsp+=sp.charAt(i);
        int m=0,n=0;
        for(int i=0;i<s.length();i++){
            char b=s.charAt(i);
            if(b>=97 && b<=122){
                r+=ra.charAt(m);
                m++;
            } 
            else {
                r+=rsp.charAt(n);
                n++;
            }
        }
        return r;
    }
}
